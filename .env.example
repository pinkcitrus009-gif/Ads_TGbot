# Скопируйте этот файл в .env и заполните реальными значениями.
# Файл .env НЕ коммитится в репозиторий (см. .gitignore).

# Токен Telegram-бота (получить у @BotFather)
TG_TOKEN=

# Ключ API OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Модель OpenRouter (по умолчанию используется openrouter/owl-alpha)
OPENROUTER_MODEL=openrouter/owl-alpha

# Строка подключения к PostgreSQL (асинхронный драйвер asyncpg).
# Пример: postgresql+asyncpg://user:password@host:5432/dbname
# Должна указывать на ПЕРСИСТЕНТНУЮ базу — иначе прогресс игроков будет теряться.
DATABASE_URL=
